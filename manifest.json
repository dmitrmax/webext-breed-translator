{
  "manifest_version": 3,
  "name": "Breed Translator",
  "author": "Maksim Dmitrichenko",  
  "version": "1.0",
  "description": "Translates Breed Bootloader",
  "browser_specific_settings": {
    "gecko": {
      "id": "{299868a5-dd74-4fed-b249-94ef169a2634}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons" : {
    "32" : "icon.svg",
    "64" : "icon.svg"
  },
  "offline_enabled" : true,
  "host_permissions": [
    "http://192.168.1.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://192.168.1.1/*"],
      "js": ["content.js"]
    }
  ]
}
